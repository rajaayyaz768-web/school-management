# Nginx reverse-proxy config for the college backend.
# Place at /etc/nginx/sites-available/college and symlink to sites-enabled:
#   sudo ln -s /etc/nginx/sites-available/college /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Assumptions:
#   - Certbot has provisioned /etc/letsencrypt/live/<domain>/
#   - Node.js listens on 127.0.0.1:5000 (PM2 cluster mode)
#   - Replace DOMAIN_PLACEHOLDER with your actual domain everywhere below
#
# One-liner to issue a cert:
#   sudo certbot --nginx -d api.yourcollege.edu.pk

# ── Upstream pool (PM2 workers all bind to the same port) ─────────────────────
upstream college_api {
    # ip_hash ensures the same client always hits the same worker during
    # Socket.IO HTTP long-polling fallback. Once the WebSocket is upgraded
    # the connection is sticky anyway, but ip_hash is needed for the handshake.
    ip_hash;
    server 127.0.0.1:5000;
    keepalive 64;            # reuse upstream connections
}

# ── HTTP → HTTPS redirect ──────────────────────────────────────────────────────
server {
    listen 80;
    server_name DOMAIN_PLACEHOLDER;
    return 301 https://$host$request_uri;
}

# ── HTTPS ─────────────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name DOMAIN_PLACEHOLDER;

    # ── TLS (managed by Certbot) ────────────────────────────────────────────
    ssl_certificate     /etc/letsencrypt/live/DOMAIN_PLACEHOLDER/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/DOMAIN_PLACEHOLDER/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # ── Security headers ────────────────────────────────────────────────────
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options    nosniff always;
    add_header X-Frame-Options           SAMEORIGIN always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin" always;

    # ── Gzip ────────────────────────────────────────────────────────────────
    gzip on;
    gzip_types application/json text/plain application/javascript text/css;
    gzip_min_length 1000;
    gzip_vary on;

    # ── DDoS: Nginx-level rate limiting (before Node.js even sees the request)
    # Complements the Redis-backed express-rate-limit in the app.
    limit_req_zone $binary_remote_addr zone=api_zone:10m rate=120r/m;
    limit_req zone=api_zone burst=30 nodelay;
    limit_req_status 429;

    # ── Health checks (bypass rate limiter, no auth) ────────────────────────
    location ~ ^/health {
        proxy_pass         http://college_api;
        proxy_http_version 1.1;
        proxy_set_header   Connection "";
        proxy_set_header   Host $host;
        access_log off;    # avoid polluting logs with probe noise
    }

    # ── REST API ────────────────────────────────────────────────────────────
    location /api/ {
        proxy_pass           http://college_api;
        proxy_http_version   1.1;
        proxy_set_header     Connection        "";  # HTTP/1.1 keepalive
        proxy_set_header     Host              $host;
        proxy_set_header     X-Real-IP         $remote_addr;
        proxy_set_header     X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header     X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
        client_max_body_size  20M;

        # Buffer tuning for API responses
        proxy_buffering      on;
        proxy_buffer_size    16k;
        proxy_buffers        8 16k;
    }

    # ── Socket.IO (WebSocket upgrade) ───────────────────────────────────────
    location /socket.io/ {
        proxy_pass           http://college_api;
        proxy_http_version   1.1;
        proxy_set_header     Upgrade    $http_upgrade;
        proxy_set_header     Connection "upgrade";
        proxy_set_header     Host              $host;
        proxy_set_header     X-Real-IP         $remote_addr;
        proxy_set_header     X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header     X-Forwarded-Proto $scheme;
        proxy_read_timeout   86400s;  # 24 h — keep WebSocket connections alive
        proxy_send_timeout   86400s;
        proxy_buffering      off;     # must be off for WebSocket
    }
}
