# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values.
#
# Generate strong secrets with:
#   openssl rand -base64 64

# ── Database ──────────────────────────────────────────────────────────────────
# Direct connection (used for migrations, seeding, Prisma Studio):
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/college?schema=public"

# When PgBouncer is active, point to port 6432 instead:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:6432/college"
# DB_CONNECTION_LIMIT=1    # let PgBouncer pool; Prisma must NOT pool on its own

# ── JWT (REQUIRED — server will refuse to start if these are missing) ─────────
JWT_SECRET="change-me-use-openssl-rand-base64-64"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="change-me-use-a-different-secret-from-JWT_SECRET"
JWT_REFRESH_EXPIRES="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="production"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Include every domain the frontend is served from (Vercel preview URLs count too).
ALLOWED_ORIGINS="https://your-app.vercel.app,http://localhost:3000"

# ── Redis (required for: caching, rate limiting, Socket.IO, BullMQ queues) ────
# Local VPS:  redis://localhost:6379
# Upstash:    rediss://default:TOKEN@HOST.upstash.io:6379
REDIS_URL="redis://localhost:6379"

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR="/var/college/uploads"

# ── Google Drive Backup ───────────────────────────────────────────────────────
# OAuth2 credentials from Google Cloud Console (Drive API enabled).
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="https://your-api-domain.com/api/v1/system/google/callback"

# ── SMTP (OTP Emails) ────────────────────────────────────────────────────────
# Easiest: Gmail + App Password (requires 2FA on the Gmail account).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-sender@gmail.com"
SMTP_PASS="xxxx-xxxx-xxxx-xxxx"
SMTP_FROM="College Portal <your-sender@gmail.com>"

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Set META_WHATSAPP_ENABLED=true to actually send messages.
# When false/absent, sends are skipped and logged — safe for dev.
#
# Setup:
#   1. Create a Meta Business Account at business.facebook.com
#   2. Add a WhatsApp Business Account and get a test phone number
#   3. Generate a permanent System User token with whatsapp_business_messaging
#      and whatsapp_business_management permissions
#   4. Create/approve the required message templates
META_WHATSAPP_ENABLED=false
META_WHATSAPP_TOKEN="your-permanent-system-user-token"
META_WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
META_WHATSAPP_TEMPLATE_NAME="fee_paid_confirmation"
META_WHATSAPP_CREDENTIALS_TEMPLATE="student_login_credentials"
META_WHATSAPP_LANGUAGE_CODE="en"

# ── VPS Backup (system backup dashboard) ─────────────────────────────────────
# Set these on the VPS to enable the backup dashboard in the principal portal.
# BACKUP_DIR="/var/backups/college"
# BACKUP_SCRIPT="/opt/college/scripts/backup-now.sh"

# ── Database connection pool tuning ──────────────────────────────────────────
# Default (no PgBouncer): 5 connections per Prisma process
# With PgBouncer:         1 (let PgBouncer multiplex)
# DB_CONNECTION_LIMIT=5
