# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/college?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-use-openssl-rand-base64-64"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="change-me-use-openssl-rand-base64-64"
JWT_REFRESH_EXPIRES="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="production"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Always include your production domain; add localhost:3000 for local dev.
ALLOWED_ORIGINS="https://college.example.pk,http://localhost:3000"

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR="/var/college/uploads"

# ── Google Drive Backup ───────────────────────────────────────────────────────
# OAuth2 credentials from Google Cloud Console (Drive API enabled).
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/v1/system/google/callback"

# ── SMTP (OTP Emails) ────────────────────────────────────────────────────────
# Used to send OTP verification emails during Google Drive setup.
# Easiest: Gmail + App Password (requires 2FA on the Gmail account).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-sender@gmail.com"
SMTP_PASS="xxxx-xxxx-xxxx-xxxx"
SMTP_FROM="College Portal <your-sender@gmail.com>"

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Set META_WHATSAPP_ENABLED=true to actually send messages.
# When false, the system logs the payload and records a SKIPPED row — safe for dev.
#
# Setup:
#  1. Create a Meta Business Account at business.facebook.com
#  2. Add a WhatsApp Business Account and get a test phone number
#  3. In the Graph API Explorer, generate a permanent (never-expiring) System User token
#     with whatsapp_business_messaging and whatsapp_business_management permissions
#  4. Create a message template named fee_paid_confirmation with the body:
#     "Dear {{1}}, the fee for {{2}} (Class {{3}}) for the month of {{4}} has been
#     received. Amount: {{5}}. Date: {{6}}. Receipt: {{7}}. — College Management."
#  5. Fill the variables below once the template is approved.
META_WHATSAPP_ENABLED=false
META_WHATSAPP_TOKEN="your-permanent-system-user-token"
META_WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
META_WHATSAPP_TEMPLATE_NAME="fee_paid_confirmation"
META_WHATSAPP_LANGUAGE_CODE="en"
