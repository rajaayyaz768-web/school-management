# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/college?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-use-openssl-rand-base64-64"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="change-me-use-openssl-rand-base64-64"
JWT_REFRESH_EXPIRES="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="production"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Always include your production domain; add localhost:3000 for local dev.
ALLOWED_ORIGINS="https://college.example.pk,http://localhost:3000"

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR="/var/college/uploads"

# ── Backup Management ─────────────────────────────────────────────────────────
# Directory where pg_dump archives are stored.
# The principal dashboard reads this directory to list and download backups.
BACKUP_DIR="/var/backups/college"
# Script executed when "Create Backup Now" is clicked in the dashboard.
BACKUP_SCRIPT="/opt/college/scripts/backup-now.sh"
